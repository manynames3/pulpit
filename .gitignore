# Terraform state — never commit
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan

# Lambda build artifacts
*.zip
__pycache__/
*.pyc

# Environment secrets — use AWS SSM or Secrets Manager in prod
*.tfvars.local
.env

# IDE
.DS_Store
.idea/
.vscode/
.wrangler/
node_modules/

# Lambda build artifacts — generated by scripts/build-lambda.sh
lambda/*/package/
